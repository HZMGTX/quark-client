{
  "schemaVersion": 1,
  "id": "quark",
  "version": "${version}",
  "name": "Quark.cc",
  "description": "A Minecraft Fabric ghost/hack client.",
  "authors": [
    "Quark Team"
  ],
  "contact": {
    "homepage": "https://github.com/HZMGTX",
    "sources": "https://github.com/HZMGTX/quark-client"
  },
  "license": "MIT",
  "icon": "assets/quark/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "cc.quark.Quark"
    ],
    "client": [
      "cc.quark.Quark"
    ]
  },
  "mixins": [
    "quark.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.7",
    "fabric-api": "*",
    "minecraft": ">=1.20.1",
    "java": ">=17"
  },
  "breaks": {
    "minecraft": "<1.20.1"
  },
  "suggests": {
    "viafabric": "*",
    "viafabricplus": "*"
  }
}